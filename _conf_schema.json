{
  "secret_id": {
    "description": "腾讯云 SecretId",
    "type": "string",
    "hint": "用于调用腾讯云 OCR 服务。"
  },
  "secret_key": {
    "description": "腾讯云 SecretKey",
    "type": "string",
    "hint": "用于调用腾讯云 OCR 服务。"
  },
  "region": {
    "description": "腾讯云地域",
    "type": "string",
    "hint": "例如 ap-guangzhou、ap-beijing。",
    "default": "ap-guangzhou"
  },
  "llm_provider": {
    "description": "大模型提供商",
    "type": "string",
    "hint": "例如 moonshot、openai、deepseek、custom。",
    "default": "moonshot"
  },
  "llm_api_key": {
    "description": "大模型 API Key",
    "type": "string",
    "hint": "用于调用大模型 API。"
  },
  "llm_base_url": {
    "description": "自定义 Base URL",
    "type": "string",
    "hint": "可选，留空则使用提供商默认地址。"
  },
  "llm_model": {
    "description": "模型名称",
    "type": "string",
    "hint": "例如 moonshot-v1-8k、gpt-4o、deepseek-chat。",
    "default": "moonshot-v1-8k"
  },
  "use_llm_for_order": {
    "description": "使用 LLM 解析接龙",
    "type": "bool",
    "hint": "启用后 /sams_order 优先使用大模型解析接龙文本。",
    "default": true
  },
  "use_llm_for_ocr": {
    "description": "使用 LLM 分析 OCR",
    "type": "bool",
    "hint": "启用后 /sams_scan 优先使用大模型从 OCR 文本中提取商品。",
    "default": true
  }
}
